{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./dist",
    "lib": ["ESNext", "DOM"],
    "types": ["node"],
    "paths": { "@/*": ["./src/*"] },
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": ["dist"]
}

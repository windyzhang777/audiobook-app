{
  "name": "audiobook-app",
  "version": "1.0.0",
  "description": "Audiobook reader web application with text-to-speech",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build:shared",
    "dev": "npm run build:shared && concurrently \"npm run dev:web\"  \"npm run dev:native\" \"npm run dev:server\" \"npm run dev:shared\"",
    "dev:web": "npm run dev -w @audiobook/web",
    "dev:native": "npm run dev -w @audiobook/native",
    "dev:server": "npm run dev -w @audiobook/server",
    "dev:shared": "npm run dev -w @audiobook/shared",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build -w @audiobook/web",
    "build:native": "npm run build -w @audiobook/native",
    "build:server": "npm run build -w @audiobook/server",
    "build:shared": "npm run build -w @audiobook/shared",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx}\"",
    "deploy:web": "npm run build:shared && npm run build:web",
    "deploy:server": "npm run build:shared && npm run build:server",
    "nuclear": "rm -rf node_modules package-lock.json packages/*/node_modules packages/*/dist packages/*/*.tsbuildinfo packages/native/.expo",
    "clean:native": "cd packages/native && npx expo start -c"
  },
  "author": "zhwind",
  "devDependencies": {
    "@tailwindcss/oxide": "^4.2.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@react-navigation/native": "^7.2.1",
    "@types/mongoose": "^5.11.96",
    "cheerio": "^1.2.0",
    "expo-status-bar": "^55.0.4",
    "iconv-lite": "^0.7.2",
    "lodash": "^4.17.23",
    "mongoose": "^9.3.1",
    "puppeteer": "^24.39.1",
    "react-native-sse": "^1.2.1",
    "unpdf": "^1.4.0"
  }
}
